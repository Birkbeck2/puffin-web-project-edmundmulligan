<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Start of meta tags -->
    <meta charset="UTF-8">
    <meta name="description" content="Web Witchcraft and Wizardry">
    <meta name="keywords" content="HTML, CSS, learning">
    <meta name="author" content="Edmund Mulligan">
    <meta name="license" content="MIT License">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="check-reading-age" content="false">
    <!-- End of meta tags -->

    <!-- Set the document title-->
    <title>Lesson{{lesson.number}}|Web Witchcraft and Wizardry</title>

    <!-- Link to Favicon -->
    <link rel="icon" type="image/svg+xml" href="../images/icons/favicon.svg">

    <!--Links for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Cormorant+Garamond:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <!-- End Google Fonts links -->

    <!-- Link to Font Awesome Icons (using CSS rather than JS)-->
    <link rel="stylesheet" href="https://kit.fontawesome.com/3895b3f1a4.css" crossorigin="anonymous">
    <!-- End Font Awesome Icons -->

    <!-- Start of CSS stylesheets section -->
    <!-- globals.css and main.css must be the first stylesheets loaded -->
    <link rel="stylesheet" href="../styles/globals.css">
    <link rel="stylesheet" href="../styles/main.css">

    <!-- component-specific stylesheets for mentor lesson pages -->
    <link rel="stylesheet" href="../styles/components/lessons-sidebar.css">

    <!-- page specific stylesheet -->
    <link rel="stylesheet" href="../styles/pages/lesson.css">
    <!-- End of CSS stylesheets section -->

    <!-- Load JavaScript files -->
    <script src="../scripts/debug.js"></script>
    <script src="../scripts/themeSwitcher.js"></script>
    <script src="../scripts/localStorage.js" defer></script>
    <script src="../scripts/toggleHeaderAndFooter.js" defer></script>
    <script src="../scripts/injectCommonCode.js" defer></script>
    <script src="../scripts/toggleSection.js" defer></script>
    <script src="../scripts/showOsInstructions.js" defer></script>
    <script src="../scripts/populateLineNumbers.js" defer></script>
    <script src="../scripts/populateLessonsMenu.js" defer></script>
    <script src="../scripts/injectLessonNavigation.js" defer></script>
    <script src="../scripts/useLessonNavigation.js" defer></script>

    <!-- End JavaScript file link -->

    <!-- Handle no JavaScript scenario -->
    <noscript>
        <link rel="stylesheet" href="../styles/components/noscript.css">
    </noscript>
</head>

<body>
    <header class="header">
        <!-- Header content is injected by JavaScript to ensure it is the same across all pages -->
    </header>

    <div class="page-container">
        <div id="lessons-nav-container">
            <!-- Lessons navigation is dynamically generated by populateLessonsMenu.js -->
        </div>

        <main class="main-content">
            <h2 class="page-title">{{lesson.page_title}}</h2>
            <!-- Lesson navigation panel will be injected here by injectLessonNavigation.js -->

            <div class="lesson-content">
                <form>
                    <fieldset class="operating-systems">
                        <legend>What computer do you use?</legend>
                        <label>
                            <input type="radio" name="os" value="windows" required>
                            Windows
                        </label>
                        <label>
                            <input type="radio" name="os" value="macos" required>
                            macOS
                        </label>
                        <label>
                            <input type="radio" name="os" value="linux" required>
                            Linux
                        </label>
                        <label>
                            <input type="radio" name="os" value="chromebook" required>
                            Chromebook
                        </label>
                        <label>
                            <input type="radio" name="os" value="android" required>
                            Android device
                        </label>
                        <label>
                            <input type="radio" name="os" value="ios" required>
                            iPhone/iPad
                        </label>
                    </fieldset>
                    <button type="submit" class="visually-hidden" aria-hidden="true" tabindex="-1">Submit</button>
                </form>

                <!-- Non-suitable platforms -->
                {{#platforms}}
                {{#non_developer}}
                <section id="{{id}}" class="lesson-section hidden lesson-install-{{id}}">
                    <div class="student-image">
                        <!--Image is injected based on choices made in student.html and saved into local storage. -->
                    </div>
                    <h3 class="lesson-title">{{cap_name}}</h3>
                    <div id="instructions-{{id}}">
                        {{{description}}}
                    </div>
                </section>
                {{/non_developer}}
                {{/platforms}}

                <!-- Introduction and warning sections (shown for all developer platforms) -->
                {{#common_sections}}
                {{#section}}
                <section id="{{section_id}}" class="lesson-section hidden {{class_list}}">
                    <div class="{{container_class}}">
                        <div class="student-image">
                            <!--Image is injected based on choices made in student.html and saved into local storage. -->
                        </div>
                        <div class="{{content_class}}">
                            <h3 class="{{title_class}}">{{title}}</h3>
                            {{{content}}}
                        </div>
                    </div>
                </section>
                {{/section}}
                {{/common_sections}}

                <!-- OS-specific sections for developer platforms -->
                {{#developer_platforms}}
                <section id="instructions-{{os_id}}" class="lesson-section hidden lesson-install-{{os_id}}">
                    <div class="student-image">
                        <!--Image is injected based on choices made in student.html and saved into local storage. -->
                    </div>
                    <h3 class="lesson-title">{{os_name}} Installation Instructions</h3>
                    <div id="instructions-{{os_id}}-content">
                        {{#tools}}
                        <section id="instructions-{{os_id}}-{{tool_id}}" class="lesson-section hidden lesson-install-{{os_id}}">
                            <div class="student-image">
                                <!--Image is injected based on choices made in student.html and saved into local storage. -->
                            </div>
                            <h3 class="faq-title">{{tool_name}}</h3>
                            <div id="{{tool_id}}-{{os_id}}">
                                {{{tool_content}}}
                            </div>
                        </section>
                        {{/tools}}
                    </div>
                </section>
                {{/developer_platforms}}

                <!-- Common sections for all developer platforms -->
                {{#common_dev_sections}}
                <section id="instructions-{{section_id}}" class="lesson-section hidden lesson-install-all">
                    <div class="student-image">
                        <!--Image is injected based on choices made in student.html and saved into local storage. -->
                    </div>
                    <h3 class="faq-title">{{section_title}}</h3>
                    <div id="{{section_id}}-content">
                        {{{section_content}}}
                    </div>
                </section>
                {{/common_dev_sections}}

            </div> <!-- End lesson-content -->
        </main>
    </div> <!-- End page-container -->

    <footer class="footer">
        <!-- Footer content is injected by JavaScript to ensure it is the same across all pages -->
    </footer>
    <div id="not-implemented" popover="auto" class="popover">
        <!-- Popover content is injected by JavaScript to ensure it is the same across all pages -->
    </div>
</body>
</html>
