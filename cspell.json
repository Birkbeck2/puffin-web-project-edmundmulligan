{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en-GB",
    "ignoreRegExpList": [
        "/\\b(?:background-)?color\\b(?=\\s*:)/"
    ],
    "flagWords": [
        "color->colour",
        "colors->colours",
        "colored->coloured",
        "coloring->colouring",
        "favorite->favourite",
        "favorites->favourites",
        "organize->organise",
        "organized->organised",
        "organizing->organising",
        "analyze->analyse",
        "analyzed->analysed",
        "analyzing->analysing",
        "customize->customise",
        "customized->customised",
        "customizing->customising"
    ],
    "words": [
        "valuenow"
    ]
}
